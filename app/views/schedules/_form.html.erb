<%= form_with(model: schedule, class: "relative bg-white rounded-[32px] shadow-[0px_25px_50px_-12px_rgba(0,11,96,0.05)] px-12 pt-12 pb-16 overflow-hidden",
  data: { controller: "schedule-form" }) do |f| %>

  <%# 装飾用アクセント %>
  <div class="absolute -top-24 -right-24 w-64 h-64 bg-[rgba(0,11,96,0.05)] rounded-full blur-[32px]"></div>

  <%# エラーメッセージ %>
  <% if schedule.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-2xl p-4 mb-8">
      <p class="text-red-600 text-sm font-medium mb-2">入力内容に問題があります：</p>
      <ul class="list-disc list-inside text-red-500 text-sm">
        <% schedule.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex flex-col gap-10 relative">
    <%# === 学習期間セクション === %>
    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-2">
        <svg class="w-[18px] h-[20px] text-[#ec7700]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span class="text-[18px] font-medium text-[#000b60]">学習期間</span>
      </div>
      <div class="grid grid-cols-2 gap-6">
        <div class="flex flex-col gap-2">
          <label class="text-[12px] text-[#767683] uppercase tracking-wider">開始日</label>
          <%= f.date_field :start_date,
            class: "bg-[#f3f4f5] rounded-xl px-4 py-3 text-[16px] text-[#191c1d] w-full focus:outline-none focus:ring-2 focus:ring-[#000b60]/20" %>
        </div>
        <div class="flex flex-col gap-2">
          <label class="text-[12px] text-[#767683] uppercase tracking-wider">終了日</label>
          <%= f.date_field :end_date,
            class: "bg-[#f3f4f5] rounded-xl px-4 py-3 text-[16px] text-[#191c1d] w-full focus:outline-none focus:ring-2 focus:ring-[#000b60]/20" %>
        </div>
      </div>
    </div>

    <%# === 1日の目標学習時間セクション === %>
    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-2">
        <svg class="w-[20px] h-[20px] text-[#ec7700]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-[18px] font-medium text-[#000b60]">1日の目標学習時間</span>
      </div>
      <div class="max-w-[320px]">
        <%= f.select :daily_study_hours,
          (1..12).map { |h| ["#{h}時間", h] },
          {},
          class: "bg-[#f3f4f5] rounded-xl px-4 py-3 text-[16px] text-[#191c1d] w-full appearance-none focus:outline-none focus:ring-2 focus:ring-[#000b60]/20 cursor-pointer" %>
      </div>
      <p class="text-[14px] text-[#454652]">※無理のない範囲で設定することをお勧めします。</p>
    </div>

    <%# === 週間スケジュールセクション === %>
    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-2">
        <svg class="w-[21px] h-[22px] text-[#ec7700]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <span class="text-[18px] font-medium text-[#000b60]">週間スケジュール</span>
      </div>
      <div class="flex gap-3" data-controller="weekday-toggle">
        <input type="hidden" name="schedule[weekdays][]" value="">
        <% %w[月 火 水 木 金 土 日].each_with_index do |day, index| %>
          <label class="cursor-pointer" data-weekday-toggle-target="label">
            <input type="checkbox" name="schedule[weekdays][]" value="<%= index %>"
              class="hidden" data-weekday-toggle-target="checkbox" data-action="change->weekday-toggle#toggle"
              <%= "checked" if schedule.weekdays&.include?(index) %>>
            <span class="inline-flex items-center justify-center w-[52px] h-[38px] rounded-full text-[14px] font-medium transition-colors"
              data-weekday-toggle-target="display">
              <%= day %>
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <%# === 学習ユニットの選択セクション === %>
    <div class="flex flex-col gap-4" data-controller="unit-select">
      <div class="flex items-center gap-2">
        <svg class="w-[19px] h-[16px] text-[#ec7700]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        <span class="text-[18px] font-medium text-[#000b60]">学習ユニットの選択</span>
      </div>

      <%# 選択済みタグ %>
      <input type="hidden" name="schedule[study_unit_ids][]" value="">
      <div class="flex flex-wrap gap-2" data-unit-select-target="selectedTags">
        <% schedule.study_unit_ids.each do |unit_id| %>
          <% unit = study_units.find { |u| u.id == unit_id } %>
          <% if unit %>
            <span class="inline-flex items-center gap-1 bg-[#cbe7f5] text-[#4e6874] text-[14px] px-3 py-1.5 rounded-lg"
              data-unit-id="<%= unit.id %>">
              <%= unit.name %>
              <button type="button" class="text-[#4e6874] hover:text-[#2d3e46]"
                data-action="click->unit-select#remove" data-unit-id="<%= unit.id %>">
                <svg class="w-2 h-2" fill="currentColor" viewBox="0 0 8 8">
                  <path d="M1 1l6 6M7 1L1 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </button>
              <input type="hidden" name="schedule[study_unit_ids][]" value="<%= unit.id %>">
            </span>
          <% end %>
        <% end %>
      </div>

      <%# ドロップダウン選択 %>
      <select class="bg-[#f3f4f5] rounded-xl px-4 py-3 text-[16px] text-[#191c1d] w-full max-w-[320px] appearance-none focus:outline-none focus:ring-2 focus:ring-[#000b60]/20 cursor-pointer"
        data-unit-select-target="dropdown" data-action="change->unit-select#add">
        <option value="">学習ユニットを選択してください...</option>
        <% study_units.each do |unit| %>
          <option value="<%= unit.id %>" data-unit-name="<%= unit.name %>"
            data-unit-select-target="option">
            <%= unit.name %>
          </option>
        <% end %>
      </select>
    </div>

    <%# === 学習メモ・目標セクション === %>
    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-2">
        <svg class="w-[18px] h-[16px] text-[#ec7700]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        <span class="text-[18px] font-medium text-[#000b60]">学習メモ・目標</span>
      </div>
      <%= f.text_area :memo,
        placeholder: "この期間に達成したいことや、自分へのメモを記入してください...",
        rows: 4,
        class: "bg-[#f3f4f5] rounded-2xl px-6 py-4 text-[16px] text-[#191c1d] w-full placeholder-[#767683] resize-none focus:outline-none focus:ring-2 focus:ring-[#000b60]/20" %>
    </div>

    <%# === アクションボタン === %>
    <div class="flex gap-4 pt-8">
      <%= link_to "キャンセル", profile_path,
        class: "flex-1 text-center py-5 bg-[#e7e8e9] text-[#48626e] text-[16px] font-medium rounded-full hover:bg-[#d9dadb] transition" %>
      <%= f.submit schedule.persisted? ? "スケジュールを更新する" : "スケジュールを保存する",
        class: "flex-1 py-5 bg-gradient-to-r from-[#ec7700] to-[#ea580c] text-white text-[16px] font-medium rounded-full shadow-[0px_20px_25px_-5px_rgba(249,115,22,0.2),0px_8px_10px_-6px_rgba(249,115,22,0.2)] hover:opacity-90 transition cursor-pointer" %>
    </div>
  </div>
<% end %>
