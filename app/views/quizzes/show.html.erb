<div class="max-w-[768px] mx-auto px-4 py-8">
  <%= form_with url: quiz_results_path, method: :post, local: true,
        data: { controller: "quiz-runner", quiz_runner_total_value: @quiz.questions.size } do %>
    <%= hidden_field_tag :quiz_id, @quiz.id %>

    <%# クイズタイトル %>
    <div class="mb-4">
      <h1 class="text-2xl font-bold text-[#1e293b]"><%= @quiz.title %></h1>
    </div>

    <%# 進捗 %>
    <div class="mb-6">
      <div class="flex items-end justify-between mb-4">
        <span class="text-2xl font-bold text-[#1e293b]" data-quiz-runner-target="counter">
          第 1 / <%= @quiz.questions.size %> 問
        </span>
      </div>
      <div class="bg-[#e2e8f0] h-[10px] rounded-full overflow-hidden">
        <div class="bg-[#3b82f6] h-full rounded-full transition-all duration-200"
             data-quiz-runner-target="progressBar"
             style="width: <%= (1.0 / @quiz.questions.size * 100).round %>%"></div>
      </div>
    </div>

    <%# 問題カード（全問DOMに出力、現在問題以外は hidden） %>
    <% @quiz.questions.each_with_index do |question, q_index| %>
      <div data-quiz-runner-target="question" class="<%= "hidden" unless q_index == 0 %>">
        <div class="bg-white border border-[#e2e8f0] rounded-2xl shadow-sm overflow-hidden mb-8">
          <% if question.image_url.present? %>
            <div class="relative aspect-[21/9] bg-[#f1f5f9] overflow-hidden">
              <%= image_tag question.image_url, class: "w-full h-full object-cover opacity-90", alt: question.body %>
              <% if question.image_credit.present? %>
                <p class="absolute bottom-1 right-2 text-[10px] text-white/80 truncate max-w-[60%] text-right">
                  出典: <%= question.image_credit %>
                </p>
              <% end %>
            </div>
          <% end %>
          <div class="p-8">
            <p class="text-xl leading-7 text-[#1e293b]"><%= question.body %></p>
          </div>
        </div>

        <%# 選択肢 %>
        <div class="grid gap-4 mb-8">
          <% question.choices.each_with_index do |choice, c_index| %>
            <label class="quiz-choice border-2 border-[#e2e8f0] rounded-xl p-[22px] flex items-center gap-4 cursor-pointer hover:border-[#3b82f6] has-[:checked]:border-[#3b82f6] has-[:checked]:bg-[rgba(59,130,246,0.05)] transition-colors">
              <%= radio_button_tag "answers[#{question.id}]", choice.id, false,
                    class: "sr-only",
                    data: { action: "change->quiz-runner#answer" } %>
              <span class="bg-[#f1f5f9] rounded-lg w-10 h-10 flex items-center justify-center text-[#64748b] font-bold text-base shrink-0">
                <%= %w[A B C D E][c_index] %>
              </span>
              <span class="flex-1 text-[#1e293b] text-base"><%= choice.body %></span>
            </label>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ナビゲーション %>
    <div class="border-t border-[#e2e8f0] pt-6 flex items-center justify-between">
      <button type="button"
              data-quiz-runner-target="prevBtn"
              data-action="click->quiz-runner#prev"
              class="border border-[#cbd5e1] rounded-xl px-6 py-3 text-[#475569] text-base font-medium hover:bg-[#f8fafc] disabled:opacity-40 disabled:cursor-not-allowed">
        ← 前の問題
      </button>
      <button type="button"
              data-quiz-runner-target="nextBtn"
              data-action="click->quiz-runner#next"
              class="bg-[#3b82f6] text-white rounded-xl px-10 py-3 text-base font-medium hover:bg-[#2563eb] shadow-[0px_10px_15px_-3px_rgba(59,130,246,0.2)]">
        次の問題へ →
      </button>
      <button type="submit"
              data-quiz-runner-target="submitBtn"
              disabled
              class="hidden bg-[#ec5b13] text-white rounded-xl px-10 py-3 text-base font-medium hover:bg-[#d14d0a] shadow-[0px_10px_15px_-3px_rgba(236,91,19,0.2)] disabled:opacity-40 disabled:cursor-not-allowed">
        採点する
      </button>
    </div>
  <% end %>
</div>
