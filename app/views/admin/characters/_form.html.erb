<%= form_with(model: [:admin, character], class: "grid grid-cols-3 gap-8 pt-2 pb-28") do |f| %>
  <%# 左カラム: メインフォーム (2/3) %>
  <div class="col-span-2 space-y-8">
    <%# 基本情報カード %>
    <div class="bg-white rounded-xl shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] p-8">
      <div class="flex gap-2 items-center mb-6">
        <svg class="size-4 text-[#424754]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
        </svg>
        <h3 class="text-lg font-bold text-[#191c1e]">基本情報</h3>
      </div>

      <div class="grid grid-cols-2 gap-6">
        <%# 名前 %>
        <div>
          <%= f.label :name, "名前 *", class: "block text-xs font-bold text-[#424754] uppercase tracking-[0.6px] mb-2" %>
          <%= f.text_field :name, placeholder: "例: 織田 信長", class: "bg-[#f2f4f6] w-full rounded-lg px-4 py-3 text-base text-[#191c1e] placeholder-[#6b7280] focus:outline-none focus:ring-2 focus:ring-[#2563eb]" %>
          <% if character.errors[:name].any? %>
            <p class="text-red-500 text-xs mt-1"><%= character.errors[:name].first %></p>
          <% end %>
        </div>

        <%# 年代 %>
        <div>
          <%= f.label :year, "年代", class: "block text-xs font-bold text-[#424754] uppercase tracking-[0.6px] mb-2" %>
          <%= f.text_field :year, placeholder: "例: 1534~1582", class: "bg-[#f2f4f6] w-full rounded-lg px-4 py-3 text-base text-[#191c1e] placeholder-[#6b7280] focus:outline-none focus:ring-2 focus:ring-[#2563eb]" %>
        </div>

        <%# 時代 %>
        <div>
          <%= f.label :period_id, "時代 *", class: "block text-xs font-bold text-[#424754] uppercase tracking-[0.6px] mb-2" %>
          <%= f.collection_select :period_id, @periods, :id, :name, { include_blank: "選択してください" }, class: "bg-[#f2f4f6] w-full rounded-lg px-4 py-3 text-base text-[#191c1e] appearance-none cursor-pointer focus:outline-none focus:ring-2 focus:ring-[#2563eb]" %>
          <% if character.errors[:period].any? %>
            <p class="text-red-500 text-xs mt-1"><%= character.errors[:period].first %></p>
          <% end %>
        </div>

        <%# 学習単位 %>
        <div>
          <%= f.label :study_unit_id, "学習単位 *", class: "block text-xs font-bold text-[#424754] uppercase tracking-[0.6px] mb-2" %>
          <%= f.collection_select :study_unit_id, @study_units, :id, :name, { include_blank: "選択してください" }, class: "bg-[#f2f4f6] w-full rounded-lg px-4 py-3 text-base text-[#191c1e] appearance-none cursor-pointer focus:outline-none focus:ring-2 focus:ring-[#2563eb]" %>
          <% if character.errors[:study_unit].any? %>
            <p class="text-red-500 text-xs mt-1"><%= character.errors[:study_unit].first %></p>
          <% end %>
        </div>

        <%# 地域 %>
        <div class="col-span-2">
          <%= f.label :region_id, "地域 *", class: "block text-xs font-bold text-[#424754] uppercase tracking-[0.6px] mb-2" %>
          <%= f.collection_select :region_id, @regions, :id, :name, { include_blank: "選択してください" }, class: "bg-[#f2f4f6] w-full rounded-lg px-4 py-3 text-base text-[#191c1e] appearance-none cursor-pointer focus:outline-none focus:ring-2 focus:ring-[#2563eb]" %>
          <% if character.errors[:region].any? %>
            <p class="text-red-500 text-xs mt-1"><%= character.errors[:region].first %></p>
          <% end %>
        </div>
      </div>
    </div>

    <%# 説明カード %>
    <div class="bg-white rounded-xl shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] p-8">
      <div class="flex gap-2 items-center mb-6">
        <svg class="size-4 text-[#424754]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
        </svg>
        <h3 class="text-lg font-bold text-[#191c1e]">説明 *</h3>
      </div>
      <%= f.text_area :description, placeholder: "人物の詳細な説明を入力してください...", rows: 10, class: "bg-[#f2f4f6] w-full rounded-lg px-4 py-3 text-base text-[#191c1e] placeholder-[#6b7280] focus:outline-none focus:ring-2 focus:ring-[#2563eb] resize-y" %>
      <% if character.errors[:description].any? %>
        <p class="text-red-500 text-xs mt-1"><%= character.errors[:description].first %></p>
      <% end %>
    </div>

    <%# 功績カード %>
    <div class="bg-white rounded-xl shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] p-8">
      <div class="flex gap-2 items-center mb-6">
        <svg class="size-4 text-[#424754]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
        </svg>
        <h3 class="text-lg font-bold text-[#191c1e]">功績 *</h3>
      </div>
      <%= f.text_area :achievement, placeholder: "この人物の主な功績を入力してください...", rows: 6, class: "bg-[#f2f4f6] w-full rounded-lg px-4 py-3 text-base text-[#191c1e] placeholder-[#6b7280] focus:outline-none focus:ring-2 focus:ring-[#2563eb] resize-y" %>
      <% if character.errors[:achievement].any? %>
        <p class="text-red-500 text-xs mt-1"><%= character.errors[:achievement].first %></p>
      <% end %>
    </div>
  </div>

  <%# 右カラム: サイドバー (1/3) %>
  <div class="col-span-1 space-y-8">
    <%# 画像カード %>
    <div class="bg-white rounded-xl shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] p-6">
      <div class="flex gap-2 items-center mb-4">
        <svg class="size-[18px] text-[#424754]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/>
        </svg>
        <h3 class="text-lg font-bold text-[#191c1e]">画像</h3>
      </div>

      <div data-controller="image-preview">
        <%# 既存画像またはプレビュー (validation失敗時は未保存blobなのでurl_forしない) %>
        <div class="mb-4 rounded-xl overflow-hidden">
          <% if character.image.attached? && character.image.blob&.persisted? %>
            <img data-image-preview-target="preview" src="<%= url_for(character.image) %>" class="w-full h-auto object-cover">
          <% elsif character.image_url.present? %>
            <img data-image-preview-target="preview" src="<%= character.image_url %>" class="w-full h-auto object-cover">
          <% else %>
            <img data-image-preview-target="preview" src="" class="w-full h-auto object-cover hidden">
          <% end %>
        </div>

        <%= f.file_field :image, id: "character_image_input", class: "hidden", accept: "image/png,image/jpeg,image/webp", data: { image_preview_target: "input", action: "change->image-preview#select" } %>

        <label for="character_image_input" data-image-preview-target="placeholder dropzone" data-action="dragover->image-preview#dragover dragleave->image-preview#dragleave drop->image-preview#drop" class="block bg-[#f2f4f6] border-2 border-dashed border-[rgba(194,198,214,0.5)] rounded-xl p-8 text-center cursor-pointer hover:border-[#2563eb] transition-colors <%= 'hidden' if (character.image.attached? && character.image.blob&.persisted?) || character.image_url.present? %>">
          <svg class="size-8 text-[#94a3b8] mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/>
          </svg>
          <p class="text-xs font-bold text-[#424754]">画像をドラッグ&ドロップ または</p>
          <p class="text-xs font-bold text-[#0058be]">クリックして選択</p>
        </label>

        <label for="character_image_input" class="block mt-3 bg-[#f2f4f6] text-[#424754] text-xs font-bold text-center px-4 py-2 rounded-lg cursor-pointer hover:bg-[#e6e8ea]">
          画像を変更する
        </label>
        <p data-image-preview-target="filename" class="hidden text-xs text-[#0058be] font-medium mt-2 text-center truncate"></p>
      </div>

      <p class="text-[11px] text-[#424754] mt-4">
        <span class="font-bold">推奨:</span> 800×800px / JPG, PNG, WebP<br>
        人物のメインビジュアルとして使用されます。
      </p>
      <% if character.errors[:image].any? %>
        <p class="text-red-500 text-xs mt-2"><%= character.errors[:image].first %></p>
      <% end %>

      <div class="mt-4">
        <%= f.label :image_credit, "画像クレジット", class: "block text-xs font-bold text-[#424754] uppercase tracking-[0.6px] mb-2" %>
        <%= f.text_field :image_credit, placeholder: "例: Photo by ...", class: "bg-[#f2f4f6] w-full rounded-lg px-4 py-3 text-sm text-[#191c1e] placeholder-[#6b7280] focus:outline-none focus:ring-2 focus:ring-[#2563eb]" %>
      </div>
    </div>
  </div>

  <%# 下部固定バー %>
  <div class="col-span-3 fixed bottom-0 left-[256px] right-0 h-20 bg-[rgba(255,255,255,0.8)] backdrop-blur-xl border-t border-[rgba(194,198,214,0.1)] flex items-center justify-between px-8 z-30">
    <%= link_to "キャンセル", admin_characters_path, class: "text-sm font-bold text-[#424754] px-6 py-3 hover:text-[#191c1e]" %>
    <%= f.submit character.persisted? ? "更新する" : "作成する", class: "bg-gradient-to-br from-[#0058be] to-[#2170e4] text-white text-sm font-bold px-10 py-3 rounded-lg shadow-[0px_10px_15px_-3px_rgba(0,88,190,0.2)] cursor-pointer hover:opacity-90" %>
  </div>
<% end %>
