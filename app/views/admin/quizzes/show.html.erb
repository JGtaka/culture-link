<%# パンくずリスト %>
<div class="flex items-center gap-2 mb-4">
  <span class="text-[11px] font-bold text-[rgba(66,71,84,0.6)] uppercase tracking-[1.1px]">
    <%= link_to "ホーム", admin_root_path, class: "hover:text-[#424754]" %>
  </span>
  <span class="text-[11px] text-[#c2c6d6]">/</span>
  <span class="text-[11px] font-bold text-[rgba(66,71,84,0.6)] uppercase tracking-[1.1px]">
    <%= link_to "小テスト", admin_quizzes_path, class: "hover:text-[#424754]" %>
  </span>
  <span class="text-[11px] text-[#c2c6d6]">/</span>
  <span class="text-[11px] font-bold text-[#424754] uppercase tracking-[1.1px] truncate max-w-[360px]"><%= @quiz.title %></span>
</div>

<%# ヘッダー %>
<div class="flex items-start justify-between mb-8 gap-8">
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-4xl font-bold text-[#191c1e] tracking-[-0.9px] truncate"><%= @quiz.title %></h1>
      <% if @quiz.published? %>
        <span class="bg-[#d1fae5] text-[#065f46] text-xs font-bold px-3 py-1 rounded-full">公開中</span>
      <% else %>
        <span class="bg-[#f2f4f6] text-[#586377] text-xs font-bold px-3 py-1 rounded-full">下書き</span>
      <% end %>
    </div>
    <p class="text-sm text-[#586377]">カテゴリー: <%= @quiz.quiz_category.name %></p>
  </div>
  <div class="flex gap-2 shrink-0">
    <%= link_to edit_admin_quiz_path(@quiz), class: "bg-[#f2f4f6] text-[#424754] text-sm font-bold px-6 py-3 rounded-lg hover:bg-[#e2e4e6]" do %>
      編集
    <% end %>
    <% if @quiz.published? %>
      <%= button_to unpublish_admin_quiz_path(@quiz),
            method: :patch,
            form: { data: { turbo_confirm: "「#{@quiz.title}」を非公開にしますか？" } },
            class: "bg-[#f2f4f6] text-[#586377] text-sm font-bold px-6 py-3 rounded-lg hover:bg-[#e2e4e6]" do %>
        非公開にする
      <% end %>
    <% else %>
      <%= button_to publish_admin_quiz_path(@quiz),
            method: :patch,
            class: "bg-gradient-to-br from-[#0058be] to-[#2170e4] text-white text-sm font-bold px-6 py-3 rounded-lg shadow-[0px_10px_15px_-3px_rgba(0,88,190,0.2)] hover:opacity-90" do %>
        公開する
      <% end %>
    <% end %>
  </div>
</div>

<%# 問題一覧カード %>
<div class="bg-white rounded-xl shadow-[0px_12px_32px_0px_rgba(25,28,30,0.04)] overflow-clip">
  <div class="flex items-center justify-between px-8 py-6 border-b border-[#f2f4f6]">
    <div class="flex items-center gap-3">
      <h2 class="text-lg font-bold text-[#191c1e]">問題</h2>
      <span class="bg-[#f2f4f6] text-[#424754] text-xs font-bold px-3 py-1 rounded-full">
        <%= @questions.size %> 問
      </span>
    </div>
    <%= link_to new_admin_quiz_question_path(@quiz), class: "flex gap-2 items-center bg-[#2563eb] text-white text-sm font-bold px-5 py-2.5 rounded-lg hover:opacity-90" do %>
      <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
      </svg>
      問題を追加
    <% end %>
  </div>

  <% if @questions.any? %>
    <ol class="divide-y divide-[#f2f4f6]">
      <% @questions.each_with_index do |question, idx| %>
        <li class="px-8 py-5 flex items-start gap-4 hover:bg-[rgba(242,244,246,0.3)] group">
          <span class="shrink-0 size-8 bg-[#2563eb] text-white text-sm font-bold rounded-full flex items-center justify-center">
            <%= idx + 1 %>
          </span>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-[#191c1e] whitespace-pre-wrap break-words"><%= question.body %></p>
            <div class="mt-2 grid grid-cols-2 gap-1.5">
              <% question.choices.each do |choice| %>
                <div class="flex items-center gap-2 text-xs">
                  <span class="size-4 rounded-full border-2 <%= choice.correct_answer ? 'border-[#10b981] bg-[#10b981]' : 'border-[#c2c6d6]' %> flex items-center justify-center">
                    <% if choice.correct_answer %>
                      <svg class="size-2.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                      </svg>
                    <% end %>
                  </span>
                  <span class="text-[#545f73] truncate"><%= choice.body %></span>
                </div>
              <% end %>
            </div>
          </div>
          <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <%= link_to edit_admin_quiz_question_path(@quiz, question), class: "bg-[#f2f4f6] p-2 rounded-lg hover:bg-[#e2e4e6]" do %>
              <svg class="size-3.5 text-[#424754]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/>
              </svg>
            <% end %>
            <%= button_to admin_quiz_question_path(@quiz, question),
                  method: :delete,
                  form: { data: { turbo_confirm: "この問題を削除しますか？" } },
                  class: "bg-[#f2f4f6] p-2 rounded-lg hover:bg-red-100" do %>
              <svg class="size-3.5 text-[#424754] hover:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
              </svg>
            <% end %>
          </div>
        </li>
      <% end %>
    </ol>
  <% else %>
    <div class="px-8 py-16 text-center">
      <p class="text-sm text-[#727785] mb-4">まだ問題が登録されていません</p>
      <%= link_to new_admin_quiz_question_path(@quiz), class: "inline-flex gap-2 items-center bg-[#2563eb] text-white text-sm font-bold px-6 py-3 rounded-lg hover:opacity-90" do %>
        最初の問題を追加
      <% end %>
    </div>
  <% end %>
</div>
