<%# ヘッダーセクション %>
<div class="mb-10">
  <h1 class="text-2xl font-bold text-[#191c1e] tracking-[-0.6px]">ダッシュボード</h1>
  <p class="text-sm text-[#545f73] mt-1">現在のシステムステータスとユーザーのアクティビティ概要</p>
</div>

<%# 統計カード %>
<div class="grid grid-cols-4 gap-6 mb-10">
  <%# 登録ユーザー数 %>
  <div class="bg-white rounded-2xl shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] p-6 flex gap-6 items-center">
    <div class="bg-[rgba(0,88,190,0.1)] rounded-full size-14 flex items-center justify-center">
      <svg class="size-6 text-[#0058be]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
      </svg>
    </div>
    <div>
      <p class="text-xs font-bold text-[#545f73] uppercase tracking-[0.6px]">登録ユーザー数</p>
      <p class="text-[30px] font-extrabold text-[#191c1e] leading-9" style="font-family: 'Manrope', sans-serif;"><%= number_with_delimiter(@total_users) %></p>
    </div>
  </div>

  <%# 今月の新規登録 %>
  <div class="bg-white rounded-2xl shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] p-6 flex gap-6 items-center">
    <div class="bg-[rgba(33,112,228,0.1)] rounded-full size-14 flex items-center justify-center">
      <svg class="size-6 text-[#2170e4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z"/>
      </svg>
    </div>
    <div>
      <p class="text-xs font-bold text-[#545f73] uppercase tracking-[0.6px]">今月の新規登録</p>
      <p class="text-[30px] font-extrabold text-[#191c1e] leading-9" style="font-family: 'Manrope', sans-serif;">+<%= @monthly_users_count %></p>
    </div>
  </div>

  <%# 公開記事数 %>
  <div class="bg-white rounded-2xl shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] p-6 flex gap-6 items-center">
    <div class="bg-[rgba(183,91,0,0.1)] rounded-full size-14 flex items-center justify-center">
      <svg class="size-6 text-[#b75b00]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
      </svg>
    </div>
    <div>
      <p class="text-xs font-bold text-[#545f73] uppercase tracking-[0.6px]">公開記事数</p>
      <p class="text-[30px] font-extrabold text-[#191c1e] leading-9" style="font-family: 'Manrope', sans-serif;"><%= @total_articles %></p>
    </div>
  </div>

  <%# クイズ総数 %>
  <div class="bg-white rounded-2xl shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] p-6 flex gap-6 items-center">
    <div class="bg-[rgba(213,224,248,0.1)] rounded-full size-14 flex items-center justify-center">
      <svg class="size-6 text-[#5b7ec2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/>
      </svg>
    </div>
    <div>
      <p class="text-xs font-bold text-[#545f73] uppercase tracking-[0.6px]">クイズ総数</p>
      <p class="text-[30px] font-extrabold text-[#191c1e] leading-9" style="font-family: 'Manrope', sans-serif;"><%= @total_quizzes %></p>
    </div>
  </div>
</div>

<%# 下段: 人気の学習単位 + 最近の登録ユーザー %>
<div class="grid grid-cols-5 gap-8">
  <%# 人気の学習単位 TOP10 %>
  <div class="col-span-3 bg-white rounded-2xl shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] p-6 overflow-clip">
    <h2 class="text-lg font-bold text-[#191c1e] mb-6">人気の学習単位 TOP10</h2>

    <div class="space-y-1">
      <%# ヘッダー行 %>
      <div class="grid grid-cols-12 px-4 py-2">
        <div class="col-span-1 text-[10px] font-bold text-[#727785] uppercase tracking-[1px]">RANK</div>
        <div class="col-span-8 text-[10px] font-bold text-[#727785] uppercase tracking-[1px]">学習単位名</div>
        <div class="col-span-3 text-[10px] font-bold text-[#727785] uppercase tracking-[1px] text-right">ビュー数</div>
      </div>

      <%# データ行 %>
      <% @popular_units.each_with_index do |unit, index| %>
        <div class="grid grid-cols-12 items-center px-4 py-4 rounded-xl">
          <div class="col-span-1">
            <span class="font-bold text-base <%= index == 0 ? 'text-[#0058be]' : 'text-[#545f73]' %>" style="font-family: 'Manrope', sans-serif;">
              <%= format("%02d", index + 1) %>
            </span>
          </div>
          <div class="col-span-8 font-medium text-base text-[#191c1e]"><%= unit.name %></div>
          <div class="col-span-3 text-base text-[#424754] text-right" style="font-family: 'Manrope', sans-serif;"><%= number_with_delimiter(unit.views_count) %></div>
        </div>
      <% end %>
    </div>
  </div>

  <%# 最近の登録ユーザー %>
  <div class="col-span-2 bg-white rounded-2xl shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] p-6 overflow-clip">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-lg font-bold text-[#191c1e]">最近の登録ユーザー</h2>
      <%= link_to "表示", admin_root_path, class: "text-xs font-bold text-[#0058be] hover:underline" %>
    </div>

    <div class="space-y-4">
      <% @recent_users.each do |user| %>
        <div class="flex gap-4 items-center p-3 rounded-xl">
          <div class="flex-1 min-w-0 overflow-clip">
            <p class="text-sm font-bold text-[#191c1e]"><%= user.name %></p>
            <p class="text-[11px] text-[#424754]"><%= user.email %></p>
          </div>
          <p class="text-[10px] font-semibold text-[#727785] text-right whitespace-nowrap"><%= user.created_at.strftime("%Y/%m/%d") %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>
