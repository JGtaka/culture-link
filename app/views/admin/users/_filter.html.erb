<div class="bg-white border border-[rgba(194,198,214,0.15)] rounded-xl shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] px-[21px] pt-[29px] pb-[21px] mb-6">
  <%= form_with url: admin_users_path, method: :get, local: true, class: "grid grid-cols-4 gap-4 items-end" do |f| %>
    <%# 検索 %>
    <div>
      <%= f.label :q, "検索", class: "block text-[11px] font-bold text-[#64748b] uppercase tracking-[0.55px] mb-[6px]" %>
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-[14px] text-[#94a3b8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <%= f.text_field :q, value: params[:q], placeholder: "メール・名前で検索...",
              class: "w-full bg-[#f8fafc] rounded-lg pl-9 pr-3 py-2 text-sm text-[#0f172a] placeholder-[#94a3b8] focus:outline-none focus:ring-2 focus:ring-[#2563eb]" %>
      </div>
    </div>

    <%# ステータス %>
    <div>
      <%= f.label :status, "ステータス", class: "block text-[11px] font-bold text-[#64748b] uppercase tracking-[0.55px] mb-[6px]" %>
      <%= f.select :status,
            [ [ "全て", "all" ], [ "正常", "active" ], [ "停止", "suspended" ] ],
            { selected: params[:status] || "all" },
            class: "w-full bg-[#f8fafc] rounded-lg px-4 py-2 text-sm text-black focus:outline-none focus:ring-2 focus:ring-[#2563eb]" %>
    </div>

    <%# 登録期間 %>
    <div>
      <label class="block text-[11px] font-bold text-[#64748b] uppercase tracking-[0.55px] mb-[6px]">登録期間</label>
      <div class="flex items-center gap-2">
        <%= f.date_field :from, value: params[:from],
              class: "flex-1 min-w-0 bg-[#f8fafc] rounded-lg px-3 py-2 text-sm text-[#0f172a] focus:outline-none focus:ring-2 focus:ring-[#2563eb]" %>
        <span class="text-[#94a3b8] text-xs">〜</span>
        <%= f.date_field :to, value: params[:to],
              class: "flex-1 min-w-0 bg-[#f8fafc] rounded-lg px-3 py-2 text-sm text-[#0f172a] focus:outline-none focus:ring-2 focus:ring-[#2563eb]" %>
      </div>
    </div>

    <%# ボタン %>
    <div class="flex gap-2">
      <%= f.submit "検索する", class: "flex-1 bg-[#2563eb] text-white font-bold text-sm rounded-lg py-2 cursor-pointer hover:bg-[#1d4ed8]" %>
      <%= link_to "リセット", admin_users_path,
            class: "text-[#64748b] font-medium text-sm px-4 py-2 hover:text-[#0f172a]" %>
    </div>
  <% end %>
</div>
