<dialog data-admin-users--confirm-modal-target="dialog"
        class="rounded-xl p-0 backdrop:bg-black/40 w-[440px] max-w-[90vw]">
  <div class="p-6">
    <div class="flex items-center gap-3 mb-4">
      <div class="size-10 bg-[#fef2f2] rounded-full flex items-center justify-center">
        <svg class="size-5 text-[#ba1a1a]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M4.938 19h14.124c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.206 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
      </div>
      <h2 class="text-lg font-bold text-[#191c1e]">アカウントを停止しますか？</h2>
    </div>
    <p class="text-sm text-[#475569] mb-6">
      「<span class="font-bold text-[#191c1e]"><%= @user.name %></span>」さんのアカウントを停止します。<br>
      停止後はログイン不可になりますが、いつでも解除できます。
    </p>
    <div class="flex justify-end gap-2">
      <button type="button"
              class="px-4 py-2 text-sm font-medium text-[#64748b] hover:text-[#0f172a]"
              data-action="click->admin-users--confirm-modal#close">
        キャンセル
      </button>
      <%= button_to "停止する", suspend_admin_user_path(@user),
            method: :patch,
            form: { class: "inline" },
            class: "bg-[#ba1a1a] text-white text-sm font-bold rounded-lg px-4 py-2 hover:bg-[#991b1b] cursor-pointer" %>
    </div>
  </div>
</dialog>
