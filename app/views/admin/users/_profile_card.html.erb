<div class="bg-white border border-[rgba(194,198,214,0.15)] rounded-xl shadow-[0px_12px_32px_0px_rgba(25,28,30,0.04)] p-[33px] mb-8">
  <div class="flex items-center gap-8">
    <%# アバター（大 96px、イニシャル、稼働インジケーター） %>
    <div class="relative">
      <% initial = @user.name.to_s.strip.grapheme_clusters.first.to_s.upcase %>
      <% palette = %w[#0ea5e9 #8b5cf6 #ec4899 #f59e0b #10b981 #2563eb #ef4444] %>
      <% bg = palette[@user.id % palette.size] %>
      <div class="size-24 rounded-full border-4 border-[#eceef0] flex items-center justify-center text-white font-bold text-3xl" style="background-color: <%= bg %>;">
        <%= initial %>
      </div>
      <% unless @user.suspended? %>
        <div class="absolute bottom-0 right-0 size-6 rounded-full bg-[#22c55e] border-4 border-white"></div>
      <% end %>
    </div>

    <%# 名前・ステータス・メール・日付 %>
    <div class="flex-1 grid grid-cols-4 gap-6 items-center">
      <div class="col-span-2">
        <div class="flex items-center gap-3 mb-1">
          <h2 class="text-2xl font-bold text-[#191c1e] leading-8"><%= @user.name %></h2>
          <% if @user.suspended? %>
            <span class="inline-flex items-center bg-[#fee2e2] text-[#be123c] text-[11px] font-bold uppercase tracking-[-0.55px] rounded-full px-3 py-1">停止</span>
          <% else %>
            <span class="inline-flex items-center bg-[#dcfce7] text-[#15803d] text-[11px] font-bold uppercase tracking-[-0.55px] rounded-full px-3 py-1">正常</span>
          <% end %>
        </div>
        <p class="text-sm font-medium text-[#424754]"><%= @user.email %></p>
      </div>

      <div>
        <p class="text-[10px] font-bold text-[#727785] uppercase tracking-[1px] mb-1">登録日</p>
        <p class="text-sm font-semibold text-[#191c1e]"><%= @user.created_at.strftime("%Y/%m/%d") %></p>
      </div>

      <div>
        <p class="text-[10px] font-bold text-[#727785] uppercase tracking-[1px] mb-1">最終ログイン</p>
        <p class="text-sm font-semibold text-[#191c1e]">
          <%= @user.current_sign_in_at ? @user.current_sign_in_at.strftime("%Y/%m/%d") : "-" %>
        </p>
      </div>
    </div>
  </div>
</div>
