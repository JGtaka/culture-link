<div class="bg-white rounded-xl shadow-[0px_12px_32px_0px_rgba(25,28,30,0.04)] overflow-clip flex flex-col">
  <%# カードヘッダー %>
  <div class="flex items-center justify-between px-6 py-5 border-b border-[#f2f4f6]">
    <h2 class="text-base font-bold text-[#191c1e]"><%= title %></h2>
    <span class="bg-[#f2f4f6] text-[#424754] text-xs font-bold px-3 py-1 rounded-full">
      <%= items.size %>件
    </span>
  </div>

  <%# 一覧 %>
  <% if items.any? %>
    <% if local_assigns[:reorder_path].present? %>
      <div id="<%= list_id %>"
           class="divide-y divide-[#f2f4f6] flex-1 min-h-[60px]"
           data-controller="sortable"
           data-sortable-url-value="<%= reorder_path %>">
        <%= render items %>
      </div>
    <% else %>
      <div id="<%= list_id %>" class="divide-y divide-[#f2f4f6] flex-1 min-h-[60px]">
        <%= render items %>
      </div>
    <% end %>
  <% else %>
    <div class="flex-1 min-h-[60px]">
      <p class="px-6 py-8 text-center text-sm text-[#727785]">まだ登録されていません</p>
    </div>
  <% end %>

  <%# 新規追加フレーム %>
  <%= turbo_frame_tag new_frame_id, class: "block border-t border-[#f2f4f6]" do %>
    <%= link_to new_path, class: "flex items-center justify-center gap-2 px-6 py-3 text-sm font-bold text-[#0058be] hover:bg-[#f7f9fb]" do %>
      <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
      </svg>
      追加
    <% end %>
  <% end %>
</div>
