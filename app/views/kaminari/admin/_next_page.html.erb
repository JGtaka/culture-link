<% if current_page.last? %>
  <span class="bg-white h-8 flex items-center justify-center px-4 rounded-lg shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] opacity-40 cursor-not-allowed">
    <span class="text-xs font-bold text-[#191c1e]">次へ</span>
  </span>
<% else %>
  <%= link_to url, class: "bg-white h-8 flex items-center justify-center px-4 rounded-lg shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] hover:bg-[#f2f4f6]" do %>
    <span class="text-xs font-bold text-[#191c1e]">次へ</span>
  <% end %>
<% end %>
