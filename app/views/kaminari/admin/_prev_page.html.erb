    <svg class="size-3 text-[#424754]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 19.5L8.25 12l7.5-7.5"/>
    </svg>
  </span>
<% else %>
  <%= link_to url, class: "bg-white size-8 flex items-center justify-center rounded-lg shadow-[0px_1px_2px_0px_rgba(0,0,0,0.05)] hover:bg-[#f2f4f6]" do %>
    <svg class="size-3 text-[#424754]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 19.5L8.25 12l7.5-7.5"/>
    </svg>
  <% end %>
<% end %>
