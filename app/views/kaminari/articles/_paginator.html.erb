<%= paginator.render do -%>
<nav class="flex items-center justify-center gap-4 pt-6">
  <%= prev_page_tag %>
  <div class="flex items-center gap-2">
    <% each_page do |page| -%>
      <% if page.left_outer? || page.right_outer? || page.inside_window? -%>
        <%= page_tag page %>
      <% elsif !page.was_truncated? -%>
        <%= gap_tag %>
      <% end -%>
    <% end -%>
  </div>
  <%= next_page_tag %>
</nav>
<% end -%>
