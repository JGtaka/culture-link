<aside class="w-64 shrink-0 flex flex-col gap-8">
  <%= form_with url: articles_path, method: :get, local: true, data: { controller: "filter", action: "change->filter#submit" } do |f| %>
    <%# 検索キーワードを保持 %>
    <%= hidden_field_tag "q[keyword]", params.dig(:q, :keyword) %>

    <%# 時代フィルター（チェックボックス） %>
    <div class="flex flex-col gap-4">
      <h3 class="text-xs font-medium text-[#94a3b8] uppercase tracking-wider">時代</h3>
      <div class="flex flex-col gap-2">
        <% @periods.each do |period| %>
          <label class="flex items-center gap-3 cursor-pointer">
            <%= check_box_tag "period_ids[]", period.id,
              params[:period_ids]&.map(&:to_s)&.include?(period.id.to_s),
              class: "size-4 rounded-lg border-[#cbd5e1] text-[#3713ec] focus:ring-[#3713ec]" %>
            <span class="text-sm text-[#475569]"><%= period.name %></span>
          </label>
        <% end %>
      </div>
    </div>

    <%# 学習単元フィルター（ドロップダウン） %>
    <div class="flex flex-col gap-4">
      <h3 class="text-xs font-medium text-[#94a3b8] uppercase tracking-wider">学習単元</h3>
      <%= select_tag :study_unit_id,
        options_from_collection_for_select(@study_units, :id, :name, params[:study_unit_id]&.to_s),
        include_blank: "すべての単元",
        class: "w-full border border-[#e2e8f0] rounded-lg px-3 py-2 text-sm text-[#0f172a]" %>
    </div>

    <%# 地域フィルター（ラジオボタン） %>
    <div class="flex flex-col gap-4">
      <h3 class="text-xs font-medium text-[#94a3b8] uppercase tracking-wider">地域</h3>
      <div class="flex flex-col gap-2">
        <label class="flex items-center gap-3 cursor-pointer">
          <%= radio_button_tag :region_id, "",
            params[:region_id].blank?,
            class: "size-4 border-[#cbd5e1] text-[#3713ec] focus:ring-[#3713ec]" %>
          <span class="text-sm text-[#475569]">すべて</span>
        </label>
        <% @regions.each do |region| %>
          <label class="flex items-center gap-3 cursor-pointer">
            <%= radio_button_tag :region_id, region.id,
              params[:region_id]&.to_s == region.id.to_s,
              class: "size-4 border-[#cbd5e1] text-[#3713ec] focus:ring-[#3713ec]" %>
            <span class="text-sm text-[#475569]"><%= region.name %></span>
          </label>
        <% end %>
      </div>
    </div>

    <%# リセットボタン %>
    <%= link_to "フィルターをリセット", articles_path,
      class: "w-full border border-[#e2e8f0] rounded-lg py-2.5 text-sm text-[#64748b] hover:bg-[#f8fafc] text-center block" %>
  <% end %>
</aside>
