GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
LINE_CHANNEL_ID=your_line_channel_id_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here
# 本番(Renderなどリバースプロキシ下)で必須。LINE Developersに登録したcallback URLと完全一致させる
# LINE_CALLBACK_URL=https://culturelink.jp/users/auth/line/callback
# LINE Messaging API用(Bot通知)。ログイン用とは別チャネル
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=your_line_messaging_channel_access_token_here
# Webhook受信時の署名検証用(Webhook実装時に有効化)
# LINE_MESSAGING_CHANNEL_SECRET=your_line_messaging_channel_secret_here
RESEND_API_KEY=your_resend_api_key_here
CLOUDINARY_CLOUD_NAME=xxxxxxxx
CLOUDINARY_API_KEY=xxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxx